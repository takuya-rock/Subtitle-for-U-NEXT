{
  "manifest_version": 3,
  "name": "Subtitle for U-NEXT",
  "version": "1.1.0",
  "permissions": ["storage", "declarativeNetRequest"],
  "host_permissions": ["https://api.opensubtitles.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://video.unext.jp/*"],
      "js": ["content.js"]
    }
  ]
}